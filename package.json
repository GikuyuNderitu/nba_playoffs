{
  "name": "nba-playoffs-viewer",
  "version": "1.0.0",
  "description": "Spoiler-Free NBA Playoffs & Tournament Viewer",
  "main": "server/index.js",
  "scripts": {
    "server:dev": "nodemon server/index.js",
    "server": "node server/index.js",
    "client:dev": "vite",
    "client:build": "vite build",
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "build": "npm run client:build",
    "test": "vitest run"
  },
  "dependencies": {
    "@distube/ytpl": "^1.2.4",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "sqlite3": "^6.0.1",
    "ytpl": "^2.3.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14",
    "vitest": "^4.1.8"
  }
}
